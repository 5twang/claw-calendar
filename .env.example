# ============================================
# Claw Calendar 环境配置模板
# ============================================
# 复制此文件为 .env (本地开发) 或 .env.production (生产环境)
# 并填写实际的值
#
# 复制命令：
#   cp .env.example .env        # 本地开发
#   cp .env.example .env.production  # 生产环境

# ============================================
# 应用配置
# ============================================
NODE_ENV=development
PORT=3000
# 生产环境请使用真实域名
BASE_URL=http://localhost:3000

# ============================================
# 数据库配置
# ============================================
# 开发环境：使用文件存储 (不需要填写)
# 生产环境：使用 PostgreSQL

# 数据库类型：file (开发) 或 postgres (生产)
DATABASE_TYPE=file

# PostgreSQL 连接信息 (生产环境)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=postgresql://claw_user:your_password@localhost:5432/claw_calendar

# ============================================
# 安全配置
# ============================================
# JWT 密钥 (生产环境必须使用强随机密钥)
JWT_SECRET=change_me_to_random_32_byte_hex_string

# 数据加密密钥 (生产环境必须使用 64 字符的十六进制字符串)
ENCRYPTION_KEY=change_me_to_64_char_hex_string_for_encryption
ENCRYPTION_SALT=change_me_to_random_salt_string
ENCRYPTION_LEVEL=full

# ============================================
# 邮件服务配置 (SMTP)
# ============================================
# 支持 QQ 邮箱、企业邮箱等 SMTP 服务

SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
# true 表示使用 SSL/TLS 连接
SMTP_SECURE=true

# 发送邮箱账号
SMTP_USER=your_smtp_user@domain.com
# 邮箱授权码 (非登录密码)
SMTP_PASS=your_smtp_auth_code

# 邮件显示的发件人名称
EMAIL_FROM=Claw Calendar <your_smtp_user@domain.com>

# ============================================
# 生产环境必填项清单
# ============================================
# 在 .env.production 中必须配置以下项目：
#
# 1. NODE_ENV=production
# 2. BASE_URL=https://your-domain.com
# 3. DATABASE_TYPE=postgres
# 4. DATABASE_URL=postgresql://user:password@host:5432/dbname
# 5. JWT_SECRET (32+ 字符随机字符串)
# 6. ENCRYPTION_KEY (64 字符十六进制字符串)
# 7. ENCRYPTION_SALT (随机字符串)
# 8. SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, EMAIL_FROM
